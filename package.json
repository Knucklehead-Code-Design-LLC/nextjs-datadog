{
  "name": "nextjs-datadog",
  "version": "0.0.0",
  "description": "Community-maintained Next.js observability integration for Datadog",
  "keywords": [
    "aws-amplify",
    "datadog",
    "logging",
    "nextjs",
    "observability",
    "opentelemetry",
    "rum",
    "tracing"
  ],
  "homepage": "https://github.com/Knucklehead-Code-Design-LLC/nextjs-datadog#readme",
  "bugs": {
    "url": "https://github.com/Knucklehead-Code-Design-LLC/nextjs-datadog/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Knucklehead-Code-Design-LLC/nextjs-datadog.git"
  },
  "license": "Apache-2.0",
  "author": "Knucklehead Code Design LLC",
  "type": "module",
  "workspaces": [
    ".",
    "examples/observability-demo"
  ],
  "sideEffects": false,
  "files": [
    "dist",
    "LICENSE",
    "NOTICE",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./instrumentation": {
      "types": "./dist/instrumentation.d.ts",
      "import": "./dist/instrumentation.js"
    },
    "./proxy": {
      "types": "./dist/proxy.d.ts",
      "import": "./dist/proxy.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=20.9.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "audit:production": "npm audit --omit=dev --audit-level=high",
    "build": "tsup",
    "changeset": "changeset",
    "check:client-boundary": "node scripts/check-client-boundary.mjs",
    "check:demo": "npm run build --workspace @nextjs-datadog/observability-demo",
    "check:package": "npm run build && publint && attw --pack . --profile esm-only && npm run check:client-boundary && node scripts/check-entrypoints.mjs",
    "clean": "node -e \"require('node:fs').rmSync('dist', { force: true, recursive: true })\"",
    "demo": "npm run build && npm run dev --workspace @nextjs-datadog/observability-demo",
    "demo:build": "npm run build && npm run check:demo",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint .",
    "prelint": "npm run build",
    "prepack": "npm run build",
    "release": "changeset publish",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "verify": "npm run format:check && npm run lint && npm run typecheck && npm run test:coverage && npm run audit:production && npm run check:package && npm run check:demo",
    "version-packages": "changeset version"
  },
  "dependencies": {
    "@vercel/otel": "2.1.3"
  },
  "peerDependencies": {
    "@datadog/browser-rum": ">=7.6.0 <8.0.0",
    "@datadog/browser-rum-nextjs": ">=7.6.0 <8.0.0",
    "@opentelemetry/api": ">=1.9.0 <2.0.0",
    "next": ">=15.0.0 <17.0.0",
    "react": ">=18.0.0 <20.0.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.5",
    "@changesets/cli": "2.31.1",
    "@datadog/browser-rum": "7.6.0",
    "@datadog/browser-rum-nextjs": "7.6.0",
    "@eslint/js": "10.0.1",
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/api-logs": "0.221.0",
    "@opentelemetry/context-async-hooks": "2.10.0",
    "@opentelemetry/instrumentation": "0.221.0",
    "@opentelemetry/resources": "2.10.0",
    "@opentelemetry/sdk-logs": "0.221.0",
    "@opentelemetry/sdk-metrics": "2.10.0",
    "@opentelemetry/sdk-trace-base": "2.10.0",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.7.0",
    "globals": "17.7.0",
    "next": "16.2.11",
    "prettier": "3.9.6",
    "publint": "0.3.22",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.65.0",
    "vitest": "4.1.10"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "postcss": "8.5.22",
    "sharp": "0.35.3"
  },
  "packageManager": "npm@10.9.3"
}
